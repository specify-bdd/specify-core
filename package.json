{
  "name": "@specify-bdd/core",
  "version": "0.4.0",
  "description": "The monorepo for all open-source package development for Specify BDD.",
  "type": "module",
  "private": true,
  "contributors": [
    "Adam Lacoste",
    "Michael Brown",
    "Wild Love"
  ],
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev:i": "pnpm dev:install",
    "dev:install": "pnpm install && pnpm generate-types && pnpm build",
    "dev:reset": "bash ./scripts/dev-reset.sh",
    "dev:watch": "tsx scripts/dev-watcher.ts",
    "generate-docs": "pnpm -r --if-present run generate-docs",
    "generate-types": "pnpm -r --if-present run generate-types",
    "lint": "prettier --check '**/*.ts' & eslint .",
    "lint:fix": "prettier --write '**/*.ts' && eslint . --fix",
    "test": "pnpm test:unit && specify",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "type-check": "rimraf **/dist/tsconfig.tsbuildinfo && tsc -b --noEmit",
    "type-check:watch": "rimraf **/dist/tsconfig.tsbuildinfo && tsc -b --noEmit --watch"
  },
  "dependencies": {
    "@specify-bdd/plugin-cli": "workspace:*",
    "@specify-bdd/quick-ref": "workspace:*",
    "@specify-bdd/specify": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@microsoft/tsdoc": "^0.15.1",
    "@microsoft/tsdoc-config": "^0.17.1",
    "@specify-bdd/eslint-plugin": "workspace:*",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.19.7",
    "@vitest/ui": "^3.2.4",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-tsdoc": "^0.4.0",
    "globals": "^16.5.0",
    "globby": "^14.1.0",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^2.4.2",
    "lodash": "^4.18.1",
    "pnpm": "^10.28.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "type-fest": "^4.41.0",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specify-bdd/specify-core.git"
  },
  "bugs": {
    "url": "https://github.com/specify-bdd/specify-core/issues"
  },
  "homepage": "https://github.com/specify-bdd/specify-core#readme",
  "packageManager": "pnpm@10.12.1"
}
